{
  "type": "tabs",
  "items": {
    "connection": {
      "type": "panel",
      "label": {
        "en": "Connection",
        "de": "Verbindung"
      },
      "items": {
        "enabled": {
          "type": "checkbox",
          "label": {
            "en": "Enable communication",
            "de": "Kommunikation aktivieren"
          },
          "xs": 12,
          "sm": 6
        },
        "host": {
          "type": "text",
          "label": {
            "en": "KentixONE IP address",
            "de": "KentixONE IP-Adresse"
          },
          "help": {
            "en": "IP address of the KentixONE SiteManager, AlarmManager, AccessManager or other SmartAPI device.",
            "de": "IP-Adresse vom KentixONE SiteManager, AlarmManager, AccessManager oder einem anderen SmartAPI-Geraet."
          },
          "newLine": true,
          "xs": 12,
          "sm": 6
        },
        "apiToken": {
          "type": "password",
          "label": {
            "en": "SmartAPI bearer token",
            "de": "SmartAPI Bearer-Token"
          },
          "help": {
            "en": "Required. Create/copy the personal API bearer token in the KentixONE user profile.",
            "de": "Erforderlich. Den persoenlichen API Bearer-Token im KentixONE Benutzerprofil erstellen/kopieren."
          },
          "xs": 12,
          "sm": 12
        },
        "protocol": {
          "type": "select",
          "label": {
            "en": "Protocol",
            "de": "Protokoll"
          },
          "options": [
            { "label": "Auto", "value": "auto" },
            { "label": "HTTPS", "value": "https" },
            { "label": "HTTP", "value": "http" }
          ],
          "xs": 12,
          "sm": 6
        },
        "port": {
          "type": "number",
          "label": {
            "en": "Port, 0 = automatic",
            "de": "Port, 0 = automatisch"
          },
          "min": 0,
          "max": 65535,
          "xs": 12,
          "sm": 6
        },
        "pollIntervalMs": {
          "type": "number",
          "label": {
            "en": "Poll interval in ms",
            "de": "Abfrageintervall in ms"
          },
          "min": 5000,
          "xs": 12,
          "sm": 6
        },
        "requestTimeoutMs": {
          "type": "number",
          "label": {
            "en": "Request timeout in ms",
            "de": "Anfrage-Timeout in ms"
          },
          "min": 1000,
          "xs": 12,
          "sm": 6
        },
        "allowSelfSigned": {
          "type": "checkbox",
          "label": {
            "en": "Allow self-signed HTTPS certificate",
            "de": "Selbstsigniertes HTTPS-Zertifikat erlauben"
          },
          "xs": 12,
          "sm": 6
        },
        "rawResponses": {
          "type": "checkbox",
          "label": {
            "en": "Store raw JSON responses",
            "de": "Rohes JSON speichern"
          },
          "xs": 12,
          "sm": 6
        }
      }
    },
    "alarm": {
      "type": "panel",
      "label": {
        "en": "Alarmgroups",
        "de": "Alarmgruppen"
      },
      "items": {
        "alarmGroupId": {
          "type": "text",
          "label": {
            "en": "Fixed alarmgroup IDs",
            "de": "Feste Alarmgruppen-IDs"
          },
          "help": {
            "en": "Optional. Comma-separated IDs used by global arm/disarm commands. Leave empty to use discovered alarmgroups.",
            "de": "Optional. Kommagetrennte IDs fuer globale Scharf/Unscharf-Befehle. Leer lassen, um erkannte Alarmgruppen zu nutzen."
          },
          "xs": 12,
          "sm": 12
        }
      }
    },
    "advanced": {
      "type": "panel",
      "label": {
        "en": "Advanced",
        "de": "Erweitert"
      },
      "items": {
        "endpoints": {
          "type": "text",
          "label": {
            "en": "Custom SmartAPI endpoints",
            "de": "Eigene SmartAPI-Endpunkte"
          },
          "help": {
            "en": "Optional JSON array or comma/newline list. Leave empty for the default official SmartAPI endpoints.",
            "de": "Optionales JSON-Array oder Komma-/Zeilenliste. Leer lassen fuer die offiziellen Standard-SmartAPI-Endpunkte."
          },
          "xs": 12,
          "sm": 12
        }
      }
    }
  }
}
